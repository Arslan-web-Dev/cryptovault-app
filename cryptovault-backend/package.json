    "@types/qrcode": "^1.5.6",
    "@types/tiny-secp256k1": "^2.0.0",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^7.0.1",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.4.2",
    "ecpair": "^3.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "express-validator": "^7.3.2",
    "handlebars": "^4.7.9",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
